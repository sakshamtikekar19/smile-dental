# Copy to server/.env for local dev. Set these in your host (e.g. Render) for production.

# Your Replicate API token (server-side ONLY — never expose to the frontend).
REPLICATE_API_TOKEN=your_replicate_token

# Comma-separated list of origins allowed to call this API. Strongly recommended
# in production to protect your Replicate credits from abuse.
# Example: https://sakshamtikekar19.github.io,http://localhost:5173
ALLOWED_ORIGINS=

# Optional tuning
# PORT=5000
# RATE_LIMIT_WINDOW_MS=60000   # rate-limit window per IP (ms)
# RATE_LIMIT_MAX=15            # max /api/smile requests per window per IP
# REPLICATE_INFERENCE_STEPS=10
# REPLICATE_POLL_MS=320
# REPLICATE_MAX_POLLS=200
