# Copy to .env.local for local dev (optional). GitHub Actions sets this for production builds.
# Your deployed Express + Replicate backend URL (must allow CORS from your Pages domain).
VITE_AI_SMILE_API=https://your-service.onrender.com/api/smile

# ── Lead capture (EmailJS) ───────────────────────────────────────────────────
# Create a free account at https://www.emailjs.com, add an email service and a
# template, then paste the IDs below. The template should reference these
# variables: {{from_name}}, {{from_email}}, {{phone}}, {{treatment}}, {{intensity}}.
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
